generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  wholesale_admin
  retail_pharmacy
}

enum OrderStatus {
  pending
  confirmed
  packed
  out_for_delivery
  delivered
  cancelled
}

enum PaymentMethod {
  cash
  mobile_money
  bank_transfer
}

enum PaymentStatus {
  pending_confirmation
  confirmed
  rejected
}

enum ComplaintType {
  wrong_item
  damaged_item
  missing_item
  delayed_delivery
  billing_issue
  other
}

enum ComplaintStatus {
  pending
  in_review
  resolved
}

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  password      String
  phone         String
  pharmacyName  String?
  role          UserRole
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // B2B approval workflow
  status            UserStatus @default(pending)
  approvedBy        String?
  verifiedAt        DateTime?
  pharmacyId        String?    @unique
  rejectionReason   String?
  location          String?
  businessRegNumber String?
  licenseNumber     String?

  approver  User?  @relation("AdminApprovals", fields: [approvedBy], references: [id], onDelete: SetNull)
  approvals User[] @relation("AdminApprovals")

  orders        Order[]
  reviews       Review[]
  complaints    Complaint[]
  receipts      Receipt[]

  @@index([status])
  @@map("users")
}

enum UserStatus {
  pending
  active
  rejected
}

model Product {
  id                 String   @id @default(cuid())
  name               String
  category           String
  price              Decimal  @db.Decimal(12, 2)
  expiryDate         DateTime?
  availabilityStatus Boolean  @default(true)
  imageUrl           String?
  deletedAt          DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  // Multi-level packaging. Stock is tracked in base units; bottles and
  // cartons are derived via conversion rates.
  // Stock is split into two pools:
  //   warehouseUnits = bulk reserve (admin-only, NEVER sellable directly)
  //   stockUnits     = sales inventory, the ONLY pool retail can order from
  // Sales stock only changes through orders (out) and admin transfers (in).
  unitsPerBottle    Int     @default(1)
  bottlesPerCarton  Int     @default(1)
  warehouseUnits    Int     @default(0)
  stockUnits        Int     @default(0)
  lowStockThreshold Int     @default(10)
  allowBottleSale   Boolean @default(true)
  allowCartonSale   Boolean @default(false)

  orderItems     OrderItem[]
  stockMovements StockMovement[]

  @@index([name])
  @@index([category])
  @@index([availabilityStatus])
  @@map("products")
}

model StockMovement {
  id         String          @id @default(cuid())
  productId  String
  product    Product         @relation(fields: [productId], references: [id])
  actionType StockActionType
  quantity   Int             // signed change in base units
  note       String?
  adminId    String?
  createdAt  DateTime        @default(now())

  @@index([productId])
  @@index([createdAt])
  @@map("stock_movements")
}

enum StockActionType {
  STOCK_ADD        // received into warehouse
  STOCK_TRANSFER   // moved from warehouse to sales inventory
  ORDER_DEDUCTION  // consumed by a customer order (sales)
  MANUAL_ADJUST    // signed correction (warehouse)
}

model Order {
  id                String      @id @default(cuid())
  retailPharmacyId  String
  status            OrderStatus @default(pending)
  // totalAmount is the FINAL payable (post-discount). subtotal is the
  // pre-discount sum of line items. discountAmount = subtotal - totalAmount.
  totalAmount       Decimal     @db.Decimal(12, 2)
  subtotal          Decimal?    @db.Decimal(12, 2)
  discountType      String?     // "percentage" | "fixed"
  discountValue     Decimal?    @db.Decimal(12, 2)
  discountAmount    Decimal     @default(0) @db.Decimal(12, 2)
  notes             String?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  retailPharmacy    User        @relation(fields: [retailPharmacyId], references: [id])
  orderItems        OrderItem[]
  payment           Payment?
  statusHistory     OrderStatusHistory[]
  review            Review?
  complaints        Complaint[]
  receipt           Receipt?

  @@index([retailPharmacyId, status])
  @@index([status])
  @@map("orders")
}

model OrderItem {
  id          String  @id @default(cuid())
  orderId     String
  productId   String
  productName String
  packLevel   String  @default("unit") // unit | bottle | carton
  unitsPerPack Int    @default(1)      // base units per pack of this level
  quantity    Int                       // number of packs ordered
  unitPrice   Decimal @db.Decimal(12, 2) // price per pack
  subtotal    Decimal @db.Decimal(12, 2)

  order      Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product    Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@map("order_items")
}

model OrderStatusHistory {
  id        String      @id @default(cuid())
  orderId   String
  status    OrderStatus
  changedAt DateTime    @default(now())
  changedBy String?

  order     Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("order_status_history")
}

model Payment {
  id        String        @id @default(cuid())
  orderId   String        @unique
  amount    Decimal       @db.Decimal(12, 2)
  method    PaymentMethod
  status    PaymentStatus @default(pending_confirmation)
  notes     String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  order     Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, status])
  @@map("payments")
}

model Receipt {
  id               String    @id @default(cuid())
  receiptNumber    String    @unique // VP-YYYY-0001
  orderId          String    @unique
  retailPharmacyId String
  totalAmount      Decimal   @db.Decimal(12, 2)
  generatedAt      DateTime  @default(now())
  printedCount     Int       @default(0)
  lastPrintedAt    DateTime?

  order            Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  retailPharmacy   User     @relation(fields: [retailPharmacyId], references: [id])

  @@index([retailPharmacyId])
  @@map("receipts")
}

// Per-year sequential counter for human-readable receipt numbers.
model ReceiptSequence {
  year      Int      @id
  lastValue Int      @default(0)
  updatedAt DateTime @updatedAt

  @@map("receipt_sequences")
}

// Public news / media posts authored by the wholesale admin.
model NewsPost {
  id          String    @id @default(cuid())
  slug        String    @unique
  title       String
  excerpt     String?
  body        String    @db.Text
  coverImage  String?
  published   Boolean   @default(false)
  publishedAt DateTime?
  authorId    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([published, publishedAt])
  @@map("news_posts")
}

// Single-row site configuration, editable by the admin and surfaced publicly.
model SiteSetting {
  id             String   @id @default("default")
  companyEmail   String?
  whatsappNumber String?
  phonePrimary   String?
  phoneSecondary String?
  address        String?
  facebookUrl    String?
  instagramUrl   String?
  twitterUrl     String?
  footerText     String?
  updatedAt      DateTime @updatedAt

  @@map("site_settings")
}

model Review {
  id               String   @id @default(cuid())
  orderId          String   @unique
  retailPharmacyId String
  rating           Int
  comment          String?
  createdAt        DateTime @default(now())

  order            Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  retailPharmacy   User     @relation(fields: [retailPharmacyId], references: [id])

  @@index([retailPharmacyId])
  @@map("reviews")
}

model Complaint {
  id               String          @id @default(cuid())
  orderId          String
  retailPharmacyId String
  type             ComplaintType
  description      String
  status           ComplaintStatus @default(pending)
  internalNotes    String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  order            Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  retailPharmacy   User            @relation(fields: [retailPharmacyId], references: [id])

  @@index([retailPharmacyId])
  @@index([status])
  @@map("complaints")
}
